{
  "name": "poliport-lojistik",
  "version": "1.0.0",
  "description": "Poliport Lojistik Araç İşaretleme Programı",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist-win": "electron-builder --win --x64",
    "dist-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.poliport.lojistik",
    "productName": "Poliport Lojistik",
    "directories": { "output": "dist" },
    "files": ["app/**/*", "main.js"],
    "win": {
      "target": [
        {"target": "nsis",     "arch": ["x64"]},
        {"target": "portable", "arch": ["x64"]}
      ]
    },
    "mac": {
      "target": [{"target": "dmg", "arch": ["x64", "arm64"]}],
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["tr_TR", "en_US"],
      "shortcutName": "Poliport Lojistik"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
